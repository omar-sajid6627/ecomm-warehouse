{
  "name": "eco-bottle",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "up": "docker compose up --build",
    "down": "docker compose down -v",
    "dev:docker": "docker compose up --build",
    "down:docker": "docker compose down -v",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "prepare": "husky install",
    "load:test": "mkdir -p reports && artillery run --output reports/run.json tests/load.yml",
    "load:report": "artillery report --output reports/run.html reports/run.json"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "artillery": "^2.0.26",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.6.2"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier -w"
    ]
  }
}
